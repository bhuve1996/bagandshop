// Search Overlay
.search-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.8);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  
  &.active {
    display: flex;
  }
  
  .search-overlay-content {
    background: white;
    padding: 40px;
    border-radius: 8px;
    width: 90%;
    max-width: 600px;
    text-align: center;
    
    .search-overlay-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      
      h3 {
        margin: 0;
        font-size: 24px;
        color: #333;
      }
      
      .close-search {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #666;
        
        &:hover {
          color: #333;
        }
      }
    }
    
    .search-form {
      display: flex;
      align-items: center;
      width: 100%;
      max-width: 550px;
      
      input[type="search"] {
        background-color: #fff;
        color: #939393;
        height: 52px;
        border: #e7e7e7 solid 2px;
        font-size: 15px;
        padding-left: 15px;
        // padding-right: 120px;
        border-radius: 5px 0 0 5px;
        flex: 1;
        
        &:focus {
          outline: none;
          border-color: #0063d1;
        }
      }
      
      button[type="submit"] {
        width: 120px;
        height: 52px;
        line-height: 52px;
        padding: 0 12px;
        border-radius: 0 5px 5px 0;
        font-size: 15px;
        font-weight: 500;
        text-transform: capitalize;
        color: #fff;
        background-color: #e74c3c;
        border: none;
        cursor: pointer;
        
        &:hover {
          background-color: #c0392b;
        }
      }
    }
  }
} 