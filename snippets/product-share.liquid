{% comment %}
  Product Share Button Snippet
  Usage: {% include 'product-share' %}
{% endcomment %}

{% assign share_url = shop.url | append: product.url %}
{% assign share_title = product.title | url_encode %}

<div class="product-share-wrapper">
  <div class="share-label">
    <span {% if settings.language_enable %}data-translate="products.product.share"{% endif %}>
      {{ 'products.product.share' | t | default: 'Share' }}:
    </span>
  </div>
  
  <div class="social-share-buttons">
    <!-- Facebook Share -->
    <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | url_encode }}" 
       target="_blank" 
       rel="noopener noreferrer"
       class="share-btn facebook-share"
       aria-label="Share on Facebook">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </a>

    <!-- WhatsApp Share -->
    <a href="https://wa.me/?text={{ share_title | append: ' ' | append: share_url | url_encode }}" 
       target="_blank" 
       rel="noopener noreferrer"
       class="share-btn whatsapp-share"
       aria-label="Share on WhatsApp">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.893 3.488"/>
      </svg>
    </a>

    <!-- Email Share -->
    <a href="mailto:?subject={{ share_title }}&body=Check out this product: {{ share_url }}" 
       class="share-btn email-share"
       aria-label="Share via Email">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
      </svg>
    </a>

    <!-- Copy Link -->
    <button type="button" 
            class="share-btn copy-link-btn copy-text-btn" 
            data-url="{{ share_url }}"
            aria-label="Copy Link"
            title="Copy product link">
      <span class="copy-text">Copy</span>
      
      <!-- Alternative: Use this icon version instead of text if preferred
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>
      </svg>
      -->
    </button>
  </div>
  
  <!-- Success message for copy link -->
  <div class="copy-success-message" style="display: none;">
    <span>{{ 'products.product.link_copied' | t | default: 'Link copied!' }}</span>
  </div>
</div>

<script>
  // Copy link functionality
  document.addEventListener('DOMContentLoaded', function() {
    // Use more specific selector to avoid conflicts
    const shareWrapper = document.querySelector('.product-share-wrapper');
    if (!shareWrapper) return;
    
    const copyBtn = shareWrapper.querySelector('.copy-link-btn');
    const successMsg = shareWrapper.querySelector('.copy-success-message');
    
    if (copyBtn) {
      copyBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const url = this.getAttribute('data-url');
        
        // Visual feedback - button press effect
        this.style.transform = 'scale(0.95)';
        setTimeout(() => {
          this.style.transform = '';
        }, 150);
        
        // Try to use the modern clipboard API
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(url).then(function() {
            showSuccessMessage();
          }).catch(function(err) {
            console.log('Clipboard API failed, using fallback:', err);
            fallbackCopyTextToClipboard(url);
          });
        } else {
          // Fallback for older browsers or non-HTTPS
          fallbackCopyTextToClipboard(url);
        }
      });
    }
    
    function fallbackCopyTextToClipboard(text) {
      const textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "fixed";
      textArea.style.left = "-999999px";
      textArea.style.top = "-999999px";
      textArea.style.opacity = "0";
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      
      try {
        const successful = document.execCommand('copy');
        if (successful) {
          showSuccessMessage();
        } else {
          console.error('Copy command was unsuccessful');
          // Show a manual copy prompt
          prompt('Copy this link:', text);
        }
      } catch (err) {
        console.error('Fallback copy failed:', err);
        // Show a manual copy prompt as last resort
        prompt('Copy this link:', text);
      }
      
      document.body.removeChild(textArea);
    }
    
    function showSuccessMessage() {
      // Add success animation to button
      if (copyBtn) {
        copyBtn.classList.add('copied');
        setTimeout(function() {
          copyBtn.classList.remove('copied');
        }, 600);
      }
      
      // Show success message
      if (successMsg) {
        successMsg.style.display = 'block';
        successMsg.style.opacity = '1';
        setTimeout(function() {
          successMsg.style.opacity = '0';
          setTimeout(function() {
            successMsg.style.display = 'none';
          }, 300);
        }, 2000);
      }
    }
  });
</script>
