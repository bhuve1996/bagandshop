{% if settings.disable_tab == blank %}
<div class="product-tabs product-page-accordion">
  <div class="container">
    {% if product.description contains '[accesories]' %}
      <div class="product-page-accordion-item">
        <div class="product-page-accordion-toggle active" role="button" tabindex="0">
          <span {% if settings.language_enable %}data-translate="products.product.tab_title_accesories"{% endif %}>{{ 'products.product.tab_title_accesories' | t }}</span>
          <i class="icon-minus accordion-icon" aria-hidden="true"></i>
        </div>
        <div class="product-page-accordion-content active">
          <div class="product-tabs-content-inner clearfix">
            {%- assign get = product.description | split:'[/accesories]' | first -%}
            {%- assign accesories = get | split:'[accesories]' | last -%}
            {% if settings.language_enable %}
              <div class="lang1">{{ accesories | split: '[lang2]' | first | replace: '<p></p>', '' | replace: '<div></div>', '' | replace: '  ', ' ' }}</div>
              <div class="lang2">{{ accesories | split: '[lang2]' | last | replace: '<p></p>', '' | replace: '<div></div>', '' | replace: '  ', ' ' }}</div>
            {% else %}
              {{ accesories | split: '[lang2]' | first | replace: '<p></p>', '' | replace: '<div></div>', '' | replace: '  ', ' ' }}
            {% endif %}
          </div>
        </div>
      </div>
      <div class="product-page-accordion-item">
        <div class="product-page-accordion-toggle" role="button" tabindex="0">
          <span {% if settings.language_enable %}data-translate="products.product.tab_title_description"{% endif %}>{{ 'products.product.tab_title_description' | t }}</span>
          <i class="icon-plus accordion-icon" aria-hidden="true"></i>
        </div>
        <div class="product-page-accordion-content">
          <div class="product-tabs-content-inner clearfix">
            {%- assign description = product.description -%}
            {%- if description contains '[countdown]' -%}
              {%- assign description = description | split:'[/countdown]' | last -%}
            {%- endif -%}
            {%- if product.description contains '[shortdesc]' -%}
              {%- assign description = description | split:'[/shortdesc]' | last -%}
            {%- endif -%}
            {%- if product.description contains '[accesories]' -%}
              {%- assign description = description | split:'[/accesories]' | last -%}
            {%- endif -%}
            {%- if description contains '[specifications]' -%}
              {%- assign description_before_specs = description | split: '[specifications]' | first -%}
              {%- assign description_after_specs = description | split: '[/specifications]' | last -%}
              {%- assign description = description_before_specs | append: description_after_specs -%}
            {%- endif -%}
            {% if settings.language_enable %}
              <div class="lang1 rte product-desc-rte">{{ description | split: '[lang2]' | first }}</div>
              <div class="lang2 rte product-desc-rte">{{ description | split: '[lang2]' | last }}</div>
            {% else %}
              <div class="rte product-desc-rte">{{ description | split: '[lang2]' | first }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    {% else %}
      <div class="product-page-accordion-item">
        <div class="product-page-accordion-toggle active" role="button" tabindex="0">
          <span {% if settings.language_enable %}data-translate="products.product.tab_title_description"{% endif %}>{{ 'products.product.tab_title_description' | t }}</span>
          <i class="icon-minus accordion-icon" aria-hidden="true"></i>
        </div>
        <div class="product-page-accordion-content active">
          <div class="product-tabs-content-inner clearfix">
            {%- assign description = product.description -%}
            {%- if description contains '[countdown]' -%}
              {%- assign description = description | split:'[/countdown]' | last -%}
            {%- endif -%}
            {%- if product.description contains '[shortdesc]' -%}
              {%- assign description = description | split:'[/shortdesc]' | last -%}
            {%- endif -%}
            {%- if product.description contains '[accesories]' -%}
              {%- assign description = description | split:'[/accesories]' | last -%}
            {%- endif -%}
            {%- if description contains '[specifications]' -%}
              {%- assign description_before_specs = description | split: '[specifications]' | first -%}
              {%- assign description_after_specs = description | split: '[/specifications]' | last -%}
              {%- assign description = description_before_specs | append: description_after_specs -%}
            {%- endif -%}
            {% if settings.language_enable %}
              <div class="lang1 rte product-desc-rte">{{ description | split: '[lang2]' | first }}</div>
              <div class="lang2 rte product-desc-rte">{{ description | split: '[lang2]' | last }}</div>
            {% else %}
              <div class="rte product-desc-rte">{{ description | split: '[lang2]' | first }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if product.description contains '[specifications]' %}
      <div class="product-page-accordion-item">
        <div class="product-page-accordion-toggle" role="button" tabindex="0">
          <span {% if settings.language_enable %}data-translate="products.product.tab_title_specifications"{% endif %}>{{ 'products.product.tab_title_specifications' | t }}</span>
          <i class="icon-plus accordion-icon" aria-hidden="true"></i>
        </div>
        <div class="product-page-accordion-content">
          <div class="product-tabs-content-inner clearfix">
            {%- assign get = product.description | split:'[/specifications]' | first -%}
            {%- assign specifications = get | split:'[specifications]' | last -%}
            {% if settings.language_enable %}
              <div class="lang1">{{ specifications | split: '[lang2]' | first | replace: '<p></p>', '' | replace: '<div></div>', '' | replace: '  ', ' ' }}</div>
              <div class="lang2">{{ specifications | split: '[lang2]' | last | replace: '<p></p>', '' | replace: '<div></div>', '' | replace: '  ', ' ' }}</div>
            {% else %}
              {{ specifications | split: '[lang2]' | first | replace: '<p></p>', '' | replace: '<div></div>', '' | replace: '  ', ' ' }}
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if settings.tab_size_chart_enable != blank %}
      <div class="product-page-accordion-item">
        <div class="product-page-accordion-toggle" role="button" tabindex="0">
          <span>
            {% if settings.language_enable %}
              <span class="lang1">{{ settings.tab_size_chart_title | split: '|' | first }}</span>
              <span class="lang2">{{ settings.tab_size_chart_title | split: '|' | last }}</span>
            {% else %}
              {{ settings.tab_size_chart_title | split: '|' | first }}
            {% endif %}
          </span>
          <i class="icon-plus accordion-icon" aria-hidden="true"></i>
        </div>
        <div class="product-page-accordion-content">
          <div class="product-tabs-content-inner clearfix">
            <img src="{{ 'tab_size_chart.png' | asset_url }}" class="img-responsive" width="800" height="600" alt="" loading="lazy" />
          </div>
        </div>
      </div>
    {% endif %}

    {% if settings.disable_tab_review == blank %}
      <div class="product-page-accordion-item">
        <div class="product-page-accordion-toggle" role="button" tabindex="0">
          <span {% if settings.language_enable %}data-translate="products.product.tab_title_review"{% endif %}>{{ 'products.product.tab_title_review' | t }}</span>
          <i class="icon-plus accordion-icon" aria-hidden="true"></i>
        </div>
        <div class="product-page-accordion-content">
          <div class="product-tabs-content-inner clearfix">
            <div class="yotpo-widget-instance" data-yotpo-instance-id="1194605" data-yotpo-product-id="{{ product.id }}" data-yotpo-name="{{ product.title | escape }}" data-yotpo-url="{{ shop.url }}{{ product.url }}" data-yotpo-image-url="{{ product.featured_image | product_img_url: 'large' |replace: '?', '%3F' | replace: '&amp;','%26'}}" data-yotpo-description="{{ product.description | escape }}"></div>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .product-page-accordion { width: 100%; padding: 8px 0; }
  .product-page-accordion-item { margin-bottom: 0; border-bottom: 1px solid #e0e0e0; }
  .product-page-accordion-item:last-child { border-bottom: none; }
  /* Top-level product tabs: primary navigation */
  .product-page-accordion .container > .product-page-accordion-item > .product-page-accordion-toggle {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    cursor: pointer !important;
    padding: 16px 0 !important;
    margin-bottom: 0 !important;
    font-size: 17px !important;
    font-weight: 700 !important;
    letter-spacing: 0.02em !important;
    text-transform: uppercase !important;
    color: #222 !important;
    user-select: none;
  }
  .product-page-accordion .container > .product-page-accordion-item > .product-page-accordion-toggle span {
    font-weight: 700 !important;
    font-size: 17px !important;
  }
  .product-page-accordion .container > .product-page-accordion-item > .product-page-accordion-content {
    display: none !important;
    padding: 20px 0 22px !important;
    border-top: 2px solid #e8e8e8 !important;
  }
  .product-page-accordion .container > .product-page-accordion-item > .product-page-accordion-content.active {
    display: block !important;
  }
  /* Shared toggle / icon (nested uses overrides below) */
  .product-page-accordion-toggle {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    cursor: pointer !important;
    padding: 15px 0 !important;
    margin-bottom: 0 !important;
    font-size: 16px !important;
    font-weight: bold !important;
    user-select: none;
  }
  .product-page-accordion-toggle span { font-weight: bold !important; font-size: 16px !important; }
  .product-page-accordion .accordion-icon {
    font-size: 18px !important;
    transition: transform 0.3s ease !important;
  }
  .product-page-accordion-content {
    display: none !important;
    padding: 20px 0 18px !important;
    border-top: 1px solid #f0f0f0 !important;
  }
  .product-page-accordion-content.active { display: block !important; }
  .product-page-accordion-content .rte {
    font-size: 16px;
    line-height: 24px;
    font-weight: 300;
    color: #555353;
  }
  .product-page-accordion-content .rte img { max-width: 100%; height: auto; }
  .product-page-accordion-content .rte p { margin: 0 0 15px; }
  .product-page-accordion-content .rte ul {
    list-style: disc outside;
    padding-left: 1.1em;
    margin-bottom: 15px;
  }
  .product-page-accordion-content .rte ul li { list-style: inherit; }
  .product-page-accordion-content .rte ol {
    list-style: decimal outside;
    padding-left: 1.25em;
    margin-bottom: 15px;
  }
  .product-page-accordion-content .rte ol li { list-style: inherit; margin-bottom: 6px; }
  .product-page-accordion-content .rte h3,
  .product-page-accordion-content .rte h2,
  .product-page-accordion-content .rte h4 {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 10px;
    color: #090909;
  }
  /* In-description sections: secondary, grouped “detail” UI */
  .product-desc-sections {
    width: 100%;
    margin-top: 4px;
    padding: 8px 14px 12px 16px;
    background: #f7f8fa;
    border: 1px solid #e4e6eb;
    border-radius: 10px;
    border-left: 4px solid #0063d1;
  }
  .product-desc-lead {
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 1px dashed #dce0e8;
    color: #444;
  }
  .product-desc-sub-accordion {
    border-bottom: 1px solid #e4e6eb;
  }
  .product-desc-sub-accordion:last-child { border-bottom: none; }
  .product-desc-sub-accordion > .product-page-accordion-toggle {
    padding: 10px 4px 10px 0 !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    color: #3d3d3d !important;
  }
  .product-desc-sub-accordion > .product-page-accordion-toggle span {
    font-size: 14px !important;
    font-weight: 600 !important;
  }
  .product-desc-sub-accordion > .product-page-accordion-toggle .accordion-icon {
    font-size: 15px !important;
    opacity: 0.75;
  }
  .product-desc-sub-accordion > .product-page-accordion-content {
    padding: 8px 0 12px 12px !important;
    margin-left: 2px;
    border-top: 1px solid #e4e6eb !important;
    border-left: 2px solid #e4e6eb;
  }
  .product-desc-sub-accordion > .product-page-accordion-content .rte {
    font-size: 15px;
    line-height: 1.55;
  }
</style>

<script>
(function () {
  function isSectionHeading(node) {
    if (!node || node.nodeType !== 1) return false;
    var t = node.tagName;
    return t === 'H2' || t === 'H3' || t === 'H4';
  }

  /** e.g. <p><strong>Features:</strong></p> — short label row, not body copy */
  function isPseudoSectionTitle(node) {
    if (!node || node.nodeType !== 1 || node.tagName !== 'P') return false;
    var firstEl = node.firstElementChild;
    if (!firstEl || firstEl.tagName !== 'STRONG') return false;
    var pText = (node.textContent || '').replace(/\s+/g, ' ').trim();
    if (pText.length > 160) return false;
    var sText = (firstEl.textContent || '').replace(/\s+/g, ' ').trim();
    if (sText.length < 2 || sText.length > 130) return false;
    var after = '';
    var seen = false;
    for (var ch = node.firstChild; ch; ch = ch.nextSibling) {
      if (ch === firstEl) {
        seen = true;
        continue;
      }
      if (seen) after += ch.nodeType === 3 ? ch.textContent : ch.textContent || '';
    }
    after = after.replace(/\s+/g, ' ').trim();
    if (after.length > 80) return false;
    return true;
  }

  function sectionMode(queue) {
    if (queue.some(isSectionHeading)) return 'heading';
    if (queue.some(isPseudoSectionTitle)) return 'pseudo';
    return null;
  }

  function isSectionStart(node, mode) {
    if (mode === 'heading') return isSectionHeading(node);
    if (mode === 'pseudo') return isPseudoSectionTitle(node);
    return false;
  }

  function titleFromSectionNode(node, mode) {
    if (mode === 'heading') return (node.textContent || '').replace(/\s+/g, ' ').trim();
    var fs = node.firstElementChild;
    if (fs && fs.tagName === 'STRONG') return (fs.textContent || '').replace(/\s+/g, ' ').trim();
    return (node.textContent || '').replace(/\s+/g, ' ').trim();
  }

  function sectionizeProductDescriptions(root) {
    root.querySelectorAll('.product-desc-rte').forEach(function (rte) {
      if (rte.getAttribute('data-desc-sectionized')) return;
      var queue = [];
      while (rte.firstChild) queue.push(rte.removeChild(rte.firstChild));
      var mode = sectionMode(queue);
      if (!mode) {
        while (queue.length) rte.appendChild(queue.shift());
        rte.setAttribute('data-desc-sectionized', 'flat');
        return;
      }
      var sections = document.createElement('div');
      sections.className = 'product-desc-sections';
      var lead = null;
      while (queue.length && !isSectionStart(queue[0], mode)) {
        if (!lead) lead = document.createElement('div');
        lead.className = 'product-desc-lead rte';
        lead.appendChild(queue.shift());
      }
      if (lead && lead.childNodes.length) sections.appendChild(lead);
      while (queue.length) {
        var h = queue.shift();
        if (!isSectionStart(h, mode)) continue;
        var item = document.createElement('div');
        item.className = 'product-page-accordion-item product-desc-sub-accordion';
        var toggle = document.createElement('div');
        toggle.className = 'product-page-accordion-toggle';
        toggle.setAttribute('role', 'button');
        toggle.setAttribute('tabindex', '0');
        var span = document.createElement('span');
        span.textContent = titleFromSectionNode(h, mode);
        var icon = document.createElement('i');
        icon.className = 'icon-plus accordion-icon';
        icon.setAttribute('aria-hidden', 'true');
        toggle.appendChild(span);
        toggle.appendChild(icon);
        var panel = document.createElement('div');
        panel.className = 'product-page-accordion-content';
        var inner = document.createElement('div');
        inner.className = 'product-tabs-content-inner clearfix rte';
        item.appendChild(toggle);
        item.appendChild(panel);
        panel.appendChild(inner);
        while (queue.length && !isSectionStart(queue[0], mode)) inner.appendChild(queue.shift());
        sections.appendChild(item);
      }
      var subs = sections.querySelectorAll('.product-desc-sub-accordion');
      if (!subs.length) {
        while (sections.firstChild) rte.appendChild(sections.firstChild);
        rte.setAttribute('data-desc-sectionized', 'flat');
        return;
      }
      rte.appendChild(sections);
      rte.setAttribute('data-desc-sectionized', '1');
      var firstToggle = sections.querySelector('.product-desc-sub-accordion > .product-page-accordion-toggle');
      var firstPanel = firstToggle && firstToggle.nextElementSibling;
      if (firstToggle && firstPanel) {
        firstToggle.classList.add('active');
        firstPanel.classList.add('active');
        var ic = firstToggle.querySelector('.accordion-icon');
        if (ic) {
          ic.classList.remove('icon-plus');
          ic.classList.add('icon-minus');
        }
      }
    });
  }

  function bindProductAccordionDelegated(root) {
    if (root.dataset.accordionDelegated) return;
    root.dataset.accordionDelegated = '1';
    function activateToggle(toggle) {
      var content = toggle.nextElementSibling;
      var icon = toggle.querySelector('.accordion-icon');
      var isOpen = toggle.classList.toggle('active');
      if (content && content.classList) content.classList.toggle('active', isOpen);
      if (icon) {
        icon.classList.remove('icon-plus', 'icon-minus');
        icon.classList.add(isOpen ? 'icon-minus' : 'icon-plus');
      }
    }
    root.addEventListener('click', function (e) {
      var toggle = e.target.closest('.product-page-accordion-toggle');
      if (!toggle || !root.contains(toggle)) return;
      activateToggle(toggle);
    });
    root.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      var toggle = e.target.closest('.product-page-accordion-toggle');
      if (!toggle || !root.contains(toggle)) return;
      e.preventDefault();
      activateToggle(toggle);
    });
  }

  function init() {
    var root = document.querySelector('.product-page-accordion');
    if (!root) return;
    sectionizeProductDescriptions(root);
    bindProductAccordionDelegated(root);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
{% endif %}
