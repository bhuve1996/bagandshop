{
  "name": "@bagandshop/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build -p tsconfig.build.json",
    "dev": "nest start --watch -p tsconfig.build.json",
    "start": "node dist/main",
    "migrate": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "migration:generate": "typeorm-ts-node-esm migration:generate -d src/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register src/seed.ts"
  },
  "dependencies": {
    "@bagandshop/shared": "*",
    "dotenv": "^16.4.5",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/typeorm": "^10.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.1",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@nestjs/cli": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  }
}
