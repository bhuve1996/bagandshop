{% if section.settings.brand_enable != blank %}
  <div data-section-id="{{ section.id }}" data-section-type="brands-slider-section">
    <div id="brands-slider-{{ section.id }}" class="box_feature_brand">
      <div class="container featured-brands">
        <div class="box_brand">
          <div class="brands-slider owl-no-narrow">
            <div
              class="data-carousel"
              data-auto="{{ section.settings.autoplay }}"
              data-items="{{ section.settings.columns }}"
              data-1600="{{ section.settings.columns }}"
              data-1200="5"
              data-992="4"
              data-768="3"
              data-640="3"
              data-480="2"
              data-320="2"
              data-paging="{{ section.settings.paging }}"
              data-nav="{{ section.settings.navigation }}"
              data-margin="{{ section.settings.margin }}"
              data-prev="{{ section.settings.prev }}"
              data-next="{{ section.settings.next }}"
              style="display: none;"
            ></div>
          </div>
          <div class="owl-carousel owl-middle-nav">
            {% for block in section.blocks %}
              <div class="item">
                <a href="{{ block.settings.link }}">
                  {% if block.settings.image != blank %}
                    {% assign img_url = block.settings.image | img_url: '216x104' %}
                  {% else %}
                    {% assign img_url = '215x105.png' | asset_url %}
                  {% endif %}
                  <img
                    src="{{ img_url }}"
                    alt="{{ section.settings.image.alt }}"
                    style="width:inherit;display: inline;"
                  >
                </a>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endif %}
<footer class="footer-wrapper">
  {% if section.settings.footer_top_enabled == 'yes' %}
    <div class="footer-top">
      <div class="container">
        <div class="row">
          <div class="{%if section.settings.footer_button_social != ''%}col-md-8{%else%}col-md-12{%endif%}">
            <div class="row">
              <div class="col-md-5">
                <div class="newsletter-content">
                  <i class="{{ settings.newsletter_footer_icon}}"></i>
                  <span class="content">
                    {% if settings.language_enable %}
                      <span class="lang1">{{ settings.newsletter_footer_content | split: '[lang2]' | first }}</span>
                      <span class="lang2">{{ settings.newsletter_footer_content | split: '[lang2]' | last }}</span>
                    {% else %}
                      {{ settings.newsletter_footer_content | split: '[lang2]' | first }}
                    {% endif %}
                  </span>
                </div>
              </div>
              <div class="col-md-7">
                {% if settings.newsletter_form_action != blank %}
                  {% assign form_action = settings.newsletter_form_action %}
                {% else %}
                  {% assign form_action = '#' %}
                {% endif %}
                <form action="{{ form_action }}" method="post" target="_blank" name="mc-embedded-subscribe-form">
                  <div class="input-group">
                    <input
                      id="fc-email"
                      type="email"
                      value="{% if customer %}{{ customer.email }}{% endif %}"
                      name="EMAIL"
                      class="input-group-field"
                      aria-label="{{ 'general.newsletter_form.newsletter_email' | t }}"
                      placeholder="{{ 'general.newsletter_form.newsletter_email' | t }}"
                    >
                    <button
                      type="submit"
                      class="btn-button"
                      name="subscribe"
                      {% if settings.language_enable %}
                        data-translate="general.newsletter_form.subscribe"
                      {% endif %}
                    >
                      {{ 'general.newsletter_form.subscribe' | t }}
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
          {% if section.settings.footer_button_social != '' %}
            <div class="col-md-4">
              {{ section.settings.footer_button_social }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}
  {% if section.settings.footer_middle_enabled == 'yes' %}
    <!-- Desktop Footer -->
    <div class="footer-middle">
      <div class="container">
        <div class="row">
          <!-- 1: Logo only -->
          <div class="col-xs-6 col-md-3 footer-item">
            <div class="footer-logo">
              {% if section.settings.footer_logo_enabled %}
                <a href="/" class="logo">
                  {% if section.settings.footer_logo != blank %}
                    {% assign logo = section.settings.footer_logo | img_url: 'master' %}
                  {% else %}
                    {% assign logo = 'logo-footer.png' | asset_url %}
                  {% endif %}
                  <img src="{{ logo }}" alt="{{ shop.name }}" width="150" height="50">
                </a>
              {% endif %}
            </div>
          </div>

          <!-- 2: Info Links -->
          <div class="col-xs-6 col-md-3 footer-item">
            <div class="block-title">Info</div>
            <ul class="footer-list">
              {% assign list = linklists[section.settings.footer_link_1] %}
              {% for link in list.links %}
                <li>
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>

          <!-- 3: Our Store Links -->
          <div class="col-xs-6 col-md-3 footer-item">
            <div class="block-title">Our Store</div>
            <ul class="footer-list">
              {% assign list2 = linklists[section.settings.footer_link_2] %}
              {% for link in list2.links %}
                <li>
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>

          <!-- 4: Contact Us -->
          <div class="col-xs-6 col-md-3 footer-item">
            <div class="block-title">Contact Us</div>
            <ul class="footer-list">
              {% if section.settings.footer_support_content %}
                <li>{{ section.settings.footer_support_content }}</li>
              {% endif %}
              {% if section.settings.footer_secure_text %}
                <li>{{ section.settings.footer_secure_text }}</li>
              {% endif %}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Accordion Footer -->
    <div class="footer-middle-mobile">
      <div class="container">
        <div class="mobile-accordion">
          <!-- 1: Logo -->
          <div class="mobile-footer-item">
            <div class="footer-logo">
              {% if section.settings.footer_logo_enabled %}
                <a href="/" class="logo">
                  {% if section.settings.footer_logo != blank %}
                    {% assign logo = section.settings.footer_logo | img_url: 'master' %}
                  {% else %}
                    {% assign logo = 'logo-footer.png' | asset_url %}
                  {% endif %}
                  <img src="{{ logo }}" alt="{{ shop.name }}" width="150" height="50">
                </a>
              {% endif %}
            </div>
          </div>

          <!-- 2: Info Links -->
          <div class="mobile-footer-item">
            <div class="block-title mobile-accordion-toggle">
              <span>Info</span>
              <i class="icon-plus accordion-icon"></i>
            </div>
            <ul class="footer-list mobile-accordion-content">
              {% assign list = linklists[section.settings.footer_link_1] %}
              {% for link in list.links %}
                <li>
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>

          <!-- 3: Our Store Links -->
          <div class="mobile-footer-item">
            <div class="block-title mobile-accordion-toggle">
              <span>Our Store</span>
              <i class="icon-plus accordion-icon"></i>
            </div>
            <ul class="footer-list mobile-accordion-content">
              {% assign list2 = linklists[section.settings.footer_link_2] %}
              {% for link in list2.links %}
                <li>
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>

          <!-- 4: Contact Us -->
          <div class="mobile-footer-item">
            <div class="block-title mobile-accordion-toggle">
              <span>Contact Us</span>
              <i class="icon-plus accordion-icon"></i>
            </div>
            <ul class="footer-list mobile-accordion-content">
              {% if section.settings.footer_support_content %}
                <li>{{ section.settings.footer_support_content }}</li>
              {% endif %}
              {% if section.settings.footer_secure_text %}
                <li>{{ section.settings.footer_secure_text }}</li>
              {% endif %}
            </ul>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  {% if section.settings.footer_bottom_enabled == 'yes' %}
    <div class="footer-bottom">
      <div class="container">
        <div class="row">
          <div class="col-md-6">
            <div class="copyright">
              {% if settings.language_enable %}
                <span class="lang1">{{ section.settings.copyrights | split: '|' | first }}</span>
                <span class="lang2">{{ section.settings.copyrights | split: '|' | last }}</span>
              {% else %}
                {{ section.settings.copyrights | split: '|' | first }}
              {% endif %}
            </div>
          </div>
          <div class="col-md-6">
            <div class="custom-text">
              {% if settings.language_enable %}
                <span class="lang1">{{ section.settings.footer_bottom_html | split: '[lang2]' | first }}</span>
                <span class="lang2">{{ section.settings.footer_bottom_html | split: '[lang2]' | last }}</span>
              {% else %}
                {{ section.settings.footer_bottom_html | split: '[lang2]' | first }}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
  <div id="back-top" class="hidden-phone">
    <a href="#top">
      <div class="sticker-wrapper">
        <div class="sticker">
          <i class="icon-up-open"></i>
        </div>
      </div>
    </a>
  </div>
</footer>
