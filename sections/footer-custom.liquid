{% comment %}
  Custom Footer Section - Created by Rohit
{% endcomment %}

<footer class="site-footer-custom" style="background-color: #f5f5f5; padding: 40px 20px;">
  <div class="container">
    <div class="footer-columns" style="display: flex; flex-wrap: wrap; gap: 40px;">
      <div class="footer-column">
        <h4>About Us</h4>
        <p>This is a custom footer section. Add your store's description here.</p>
      </div>
      <div class="footer-column">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/collections/all">Shop All</a></li>
          <li><a href="/pages/about-us">About Us</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>Follow Us</h4>
        <ul class="social-links" style="display: flex; gap: 10px;">
          <li><a href="#"><img src="{{ 'facebook.svg' | asset_url }}" alt="Facebook" width="24"></a></li>
          <li><a href="#"><img src="{{ 'instagram.svg' | asset_url }}" alt="Instagram" width="24"></a></li>
          <li><a href="#"><img src="{{ 'twitter.svg' | asset_url }}" alt="Twitter" width="24"></a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}